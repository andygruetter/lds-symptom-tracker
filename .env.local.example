# Supabase (Story 1.3)
# Werte findest du im Supabase Dashboard unter: Settings → API
NEXT_PUBLIC_SUPABASE_URL=        # Project URL (https://<project-id>.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon/public Key (sicher für Client-Side)
SUPABASE_SERVICE_ROLE_KEY=  # service_role Key (NUR Server-Side! Bypassed RLS!)

# Apple Sign-In (Story 1.4)
# Apple Developer Console → Certificates, Identifiers & Profiles → Keys
# Wird für Supabase CLI (lokale Entwicklung) benötigt — .p8 Key → JWT Secret
# ACHTUNG: Muss alle 6 Monate rotiert werden!
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# KI-Pipeline (Epic 2/3)
ANTHROPIC_API_KEY=         # Claude API — Symptom-Extraktion (Epic 2)
OPENAI_API_KEY=            # OpenAI API — Sprach-Transkription (Story 3.2)
INTERNAL_API_SECRET=       # Interner Token für /api/ai/extract Route

# PWA / Push (Story 1.5 + Story 3.4)
# Generieren via: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_KEY=     # VAPID Public Key (Client-seitig, für PushManager.subscribe)
VAPID_PRIVATE_KEY=         # VAPID Private Key (Server-only, für web-push.sendNotification)
VAPID_SUBJECT=mailto:app@example.com  # Kontakt-Info für Push-Service

# Serwist — unterdrückt Turbopack-Warnung im Dev-Modus
SERWIST_SUPPRESS_TURBOPACK_WARNING=1

# Sharing (Epic 5)
SHARING_HMAC_SECRET=rZd2XlcZZEZ5xeNLdPHFwZOOrTLQYlyUdPdRdqgt86I=

# Monitoring (optional)
SENTRY_DSN=
# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
